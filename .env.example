# ==============================================================================
# Environment Configuration - Example Template
# Duplicate this file to '.env' and adjust the variables as required.
# ==============================================================================

# ── Server Config ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL Database Config ────────────────────────────────────────────────
# For local run: use 'localhost' and your local PostgreSQL port (e.g. 5432 or 5433)
# For Docker run: use 'postgres' as host and '5432' as internal port
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=****
DB_NAME=realtime_orders

# ── CORS Settings ─────────────────────────────────────────────────────────────
# Restrict this to your production domain (e.g., https://orders.yourdomain.com)
CORS_ORIGIN=*

# ── Socket.IO Engine Config ───────────────────────────────────────────────────
# Timeouts in milliseconds for connection stability
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
